page {
  background-color: #0a0a0f;
  color: #e8e8e8;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
}
.safe-bottom { padding-bottom: env(safe-area-inset-bottom); }
.container { padding: 40rpx 32rpx; min-height: 100vh; box-sizing: border-box; }
.accent { color: #2563eb; }
.accent-bg { background: linear-gradient(135deg, #2563eb 0%, #7c3aed 100%); }
.card {
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}
.btn-primary {
  background: linear-gradient(135deg, #2563eb 0%, #7c3aed 100%);
  color: #fff; border: none; border-radius: 12rpx;
  padding: 24rpx 48rpx; font-size: 30rpx; font-weight: 500;
  text-align: center; letter-spacing: 2rpx;
}
.btn-primary::after { border: none; }
.btn-outline {
  background: transparent; color: #2563eb;
  border: 2rpx solid #2563eb; border-radius: 12rpx;
  padding: 22rpx 48rpx; font-size: 30rpx; text-align: center;
}
.btn-outline::after { border: none; }
.divider { width: 100%; height: 1rpx; background: linear-gradient(90deg, transparent, rgba(37,99,235,0.4), transparent); margin: 32rpx 0; }
.tag {
  display: inline-block; background: rgba(37,99,235,0.15);
  color: #60a5fa; font-size: 22rpx; padding: 6rpx 16rpx;
  border-radius: 6rpx; margin-right: 12rpx; margin-bottom: 8rpx;
}
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 120rpx 0; }
.empty-text { color: #666; font-size: 28rpx; }
