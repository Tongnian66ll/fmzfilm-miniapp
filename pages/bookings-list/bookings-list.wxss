.page { min-height: 100vh; background: #0a0a0f; padding-bottom: 40rpx; }
.container { padding: 24rpx; }

.section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24rpx; }
.section-title { font-size: 32rpx; font-weight: 700; color: #ffffff; }

/* 预约卡片 */
.booking-card {
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.08);
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.card-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
}

.status {
  font-size: 24rpx; font-weight: 600; padding: 6rpx 16rpx; border-radius: 8rpx;
}
.status-pending { background: rgba(245,158,11,0.15); color: #f59e0b; }
.status-confirmed { background: rgba(37,99,235,0.15); color: #2563eb; }
.status-completed { background: rgba(34,197,94,0.15); color: #22c55e; }
.status-cancelled { background: rgba(255,255,255,0.08); color: #888; }

.booking-time { font-size: 22rpx; color: #888; }

.card-body { padding: 20rpx 24rpx; }

.info-row {
  display: flex; align-items: flex-start; margin-bottom: 16rpx;
}
.info-row:last-child { margin-bottom: 0; }
.info-label {
  width: 160rpx; font-size: 26rpx; color: #888; flex-shrink: 0;
}
.info-value {
  font-size: 26rpx; color: #fff; flex: 1; word-break: break-all;
}
.info-value.price { color: #f59e0b; font-weight: 600; }
.info-value.desc { color: #ccc; line-height: 1.5; }

.card-footer {
  padding: 16rpx 24rpx; border-top: 1rpx solid rgba(255,255,255,0.06);
  display: flex; justify-content: flex-end;
}

.btn-wechat {
  background: rgba(7,193,96,0.15); border: 1rpx solid rgba(7,193,96,0.3);
  border-radius: 12rpx; padding: 12rpx 24rpx;
  font-size: 24rpx; color: #07c160; font-weight: 500;
}

.list-footer {
  text-align: center; padding: 32rpx 0;
}
.footer-text { display: block; font-size: 22rpx; color: #666; margin-bottom: 8rpx; }
.footer-tip { display: block; font-size: 22rpx; color: #888; }

/* 空状态 */
.empty-state {
  display: flex; flex-direction: column; align-items: center;
  justify-content: center; min-height: 60vh; padding: 60rpx;
}
.empty-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.empty-title { font-size: 32rpx; color: #fff; font-weight: 600; margin-bottom: 12rpx; }
.empty-desc { font-size: 26rpx; color: #888; margin-bottom: 40rpx; }
.empty-btn {
  background: linear-gradient(135deg, #2563eb, #1d4ed8);
  border-radius: 16rpx; padding: 20rpx 48rpx;
  font-size: 28rpx; color: #fff; font-weight: 600;
}

.loading { text-align: center; padding: 80rpx; color: #888; font-size: 28rpx; }
