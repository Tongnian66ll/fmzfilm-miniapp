/* 用户信息区 */
.profile-header { display: flex; align-items: center; padding: 40rpx 0; }
.avatar-wrap { margin-right: 28rpx; }
.avatar {
  width: 120rpx; height: 120rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(37,99,235,0.5);
}
.avatar-placeholder {
  background: linear-gradient(135deg, #2563eb 0%, #7c3aed 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 48rpx;
  font-weight: 700;
}
.user-info { flex: 1; }
.user-name { display: block; font-size: 36rpx; font-weight: 600; color: #fff; }
.user-desc { display: block; font-size: 24rpx; color: rgba(255,255,255,0.4); margin-top: 6rpx; }
.login-btn {
  background: linear-gradient(135deg, #2563eb 0%, #7c3aed 100%);
  color: #fff; font-size: 26rpx; padding: 14rpx 36rpx; border-radius: 40rpx;
}

/* 菜单 */
.menu-list { margin-top: 16rpx; }
.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 16rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.05);
}
.menu-icon { font-size: 40rpx; margin-right: 24rpx; }
.menu-text { flex: 1; }
.menu-label { display: block; font-size: 30rpx; color: #fff; }
.menu-desc { display: block; font-size: 22rpx; color: rgba(255,255,255,0.4); margin-top: 4rpx; }
.menu-arrow { font-size: 36rpx; color: rgba(255,255,255,0.3); }

/* 底部 */
.footer-info { text-align: center; padding: 60rpx 0 40rpx; }
.footer-text { display: block; font-size: 22rpx; color: rgba(255,255,255,0.25); line-height: 1.8; }

/* 微信二维码弹窗 */
.qr-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}
.qr-popup {
  width: 600rpx;
  background: #1a1a2e;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  text-align: center;
  border: 1rpx solid rgba(37,99,235,0.3);
}
.qr-title { display: block; font-size: 36rpx; font-weight: 700; color: #fff; margin-bottom: 12rpx; }
.qr-subtitle { display: block; font-size: 24rpx; color: rgba(255,255,255,0.5); margin-bottom: 32rpx; }
.qr-image {
  width: 400rpx; height: 400rpx;
  border-radius: 16rpx;
  margin: 0 auto 24rpx;
  display: block;
}
.qr-tip { display: block; font-size: 22rpx; color: rgba(255,255,255,0.4); margin-bottom: 32rpx; }
.qr-btns { display: flex; gap: 16rpx; }
.qr-btn { flex: 1; font-size: 26rpx; padding: 18rpx 0; }

/* 待处理角标 */
.menu-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.badge {
  background: #ff4444;
  border-radius: 20rpx;
  padding: 2rpx 12rpx;
  min-width: 36rpx;
  text-align: center;
}
.badge-text {
  font-size: 22rpx;
  color: #fff;
  font-weight: 600;
}

/* 关于我们弹窗 */
.about-popup {
  width: 600rpx;
  background: #1a1a2e;
  border-radius: 24rpx;
  padding: 48rpx 40rpx 24rpx;
  text-align: center;
  border: 1rpx solid rgba(37,99,235,0.3);
  position: relative;
}
.about-title { display: block; font-size: 36rpx; font-weight: 700; color: #fff; margin-bottom: 8rpx; }
.about-company { display: block; font-size: 24rpx; color: rgba(255,255,255,0.5); margin-bottom: 24rpx; }
.about-desc { display: block; font-size: 26rpx; color: rgba(255,255,255,0.7); line-height: 1.8; margin-bottom: 32rpx; }
.about-close {
  font-size: 26rpx; color: #2563eb; padding: 12rpx 0; margin-bottom: 12rpx;
}
.about-version {
  display: block; font-size: 20rpx; color: rgba(255,255,255,0.12); padding: 8rpx 0 12rpx;
}

/* 密码弹窗 */
.pwd-popup {
  width: 560rpx;
  background: #1a1a2e;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  text-align: center;
  border: 1rpx solid rgba(37,99,235,0.3);
}
.pwd-title { display: block; font-size: 34rpx; font-weight: 700; color: #fff; margin-bottom: 8rpx; }
.pwd-subtitle { display: block; font-size: 24rpx; color: rgba(255,255,255,0.5); margin-bottom: 32rpx; }
.pwd-input {
  background: rgba(255,255,255,0.08);
  border: 1rpx solid rgba(255,255,255,0.15);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #fff;
  margin-bottom: 28rpx;
  text-align: center;
}
.pwd-btn {
  background: linear-gradient(135deg, #2563eb, #1d4ed8);
  border-radius: 14rpx;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
  margin-bottom: 20rpx;
}
.pwd-close {
  display: block; font-size: 24rpx; color: rgba(255,255,255,0.4); padding: 8rpx 0;
}
