<view class="page container">
  <!-- 用户信息 -->
  <view class="user-section">
    <view class="avatar-wrap" bindtap="getUserProfile" wx:if="{{!isLoggedIn}}">
      <image class="avatar" src="/images/avatar-taoyx.webp" mode="aspectFill" />
      <view class="avatar-mask">
        <text class="avatar-mask-text">点击登录</text>
      </view>
    </view>
    <view class="avatar-wrap" bindtap="getUserProfile" wx:else>
      <image class="avatar" src="{{userInfo.avatarUrl || '/images/avatar-taoyx.webp'}}" mode="aspectFill" />
    </view>
    <view class="user-info">
      <text class="user-name">{{userInfo.nickName || '访客用户'}}</text>
      <text class="user-desc" wx:if="{{isLoggedIn}}">欢迎回来</text>
      <text class="user-desc" wx:else>点击头像登录</text>
    </view>
  </view>

  <!-- 菜单 -->
  <view class="menu-list">
    <view class="menu-item" wx:for="{{menuItems}}" wx:key="id" bindtap="onMenuTap" data-id="{{item.id}}">
      <view class="menu-left">
        <text class="menu-icon">{{item.icon}}</text>
        <text class="menu-label">{{item.label}}</text>
      </view>
      <view class="menu-right">
        <text class="menu-desc" wx:if="{{item.desc}}">{{item.desc}}</text>
        <view class="badge" wx:if="{{item.id === 'my-bookings' && pendingCount > 0}}">
          <text class="badge-text">{{pendingCount}}</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 微信二维码弹窗 -->
  <view class="qr-mask" wx:if="{{showWechatQR}}" bindtap="closeWechatQR">
    <view class="qr-popup" catchtap="">
      <image class="qr-image" src="/images/wechat-qr.jpg" mode="aspectFit" show-menu-by-longpress />
      <text class="qr-tip">长按识别二维码添加微信</text>
      <text class="qr-wechat">微信号：njfmz1</text>
      <view class="qr-close" bindtap="closeWechatQR">✕</view>
    </view>
  </view>

  <!-- 关于我们弹窗 -->
  <view class="qr-mask" wx:if="{{showAbout}}" catchtap="closeAbout">
    <view class="about-popup" catchtap="">
      <text class="about-title">分秒帧影视</text>
      <text class="about-company">南京分秒帧影视有限公司</text>
      <text class="about-desc">专业影视制作团队\n50+项目经验 · 18项电影节入围\n从创意到成片，以帧级精度打磨每一部作品</text>
      <view class="about-close" bindtap="closeAbout">关闭</view>
      <!-- 彩蛋触发点 -->
      <text class="about-version" catchtap="onVersionTap">v1.0</text>
    </view>
  </view>

  <!-- 密码输入弹窗 -->
  <view class="qr-mask" wx:if="{{showPwdDialog}}" bindtap="closePwd">
    <view class="pwd-popup" catchtap="">
      <text class="pwd-title">🔐 管理员验证</text>
      <text class="pwd-subtitle">请输入管理密码</text>
      <input class="pwd-input" password="{{true}}" placeholder="请输入密码" value="{{pwdInput}}" bindinput="onPwdInput" bindconfirm="verifyPassword" />
      <view class="pwd-btn" bindtap="verifyPassword">确认</view>
      <text class="pwd-close" bindtap="closePwd">取消</text>
    </view>
  </view>
</view>
