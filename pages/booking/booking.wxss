.section-desc {
  display: block; font-size: 26rpx; color: rgba(255,255,255,0.5); margin-top: 8rpx;
}

/* 微信卡 */
.wechat-card {
  text-align: center;
  padding: 48rpx 32rpx;
}
.wechat-label {
  display: block; font-size: 28rpx; color: rgba(255,255,255,0.7); margin-bottom: 32rpx;
}
.wechat-qr {
  width: 360rpx; height: 360rpx; border-radius: 16rpx; margin: 0 auto 24rpx; display: block;
}
.wechat-id {
  display: block; font-size: 24rpx; color: rgba(255,255,255,0.4); margin-bottom: 32rpx;
}
.wechat-btn { font-size: 28rpx; }

.form-alt-title {
  display: block; font-size: 26rpx; color: rgba(255,255,255,0.5); margin-bottom: 32rpx; text-align: center;
}

/* 报价信息卡 */
.quote-info { display: flex; align-items: center; gap: 20rpx; margin-bottom: 40rpx; }
.quote-label { font-size: 24rpx; color: rgba(255,255,255,0.5); }
.quote-price { font-size: 44rpx; font-weight: 700; color: #2563eb; }
.quote-service { font-size: 24rpx; color: rgba(255,255,255,0.4); margin-left: auto; }

/* 表单 */
.form { margin-bottom: 48rpx; }
.form-item { margin-bottom: 32rpx; }
.form-label { display: block; font-size: 26rpx; color: rgba(255,255,255,0.7); margin-bottom: 12rpx; }
.required { color: #ef4444; }
.form-input {
  width: 100%; height: 88rpx; background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.1); border-radius: 12rpx;
  padding: 0 24rpx; color: #fff; font-size: 28rpx; box-sizing: border-box;
}
.form-picker {
  height: 88rpx; line-height: 88rpx; background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.1); border-radius: 12rpx;
  padding: 0 24rpx; color: #fff; font-size: 28rpx;
}
.form-picker.placeholder { color: rgba(255,255,255,0.3); }
.form-textarea {
  width: 100%; min-height: 180rpx; background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.1); border-radius: 12rpx;
  padding: 20rpx 24rpx; color: #fff; font-size: 28rpx; box-sizing: border-box;
}

.form-footer { text-align: center; }
.submit-btn { width: 100%; height: 96rpx; line-height: 96rpx; font-size: 32rpx; }
