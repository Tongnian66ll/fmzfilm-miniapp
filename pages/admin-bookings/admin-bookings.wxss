.page { padding-bottom: 60rpx; background: #0a0a0f; color: #fff; min-height: 100vh; }
.section-header { padding: 40rpx 32rpx 20rpx; }
.section-overline { font-size: 24rpx; color: #5b7fff; letter-spacing: 4rpx; display: block; margin-bottom: 8rpx; }
.section-title { font-size: 44rpx; font-weight: 700; color: #fff; display: block; margin-bottom: 8rpx; }
.section-desc { font-size: 26rpx; color: #999; display: block; }

.loading { text-align: center; padding: 80rpx; color: #666; font-size: 28rpx; }

/* 筛选标签 */
.filter-tabs {
  display: flex;
  gap: 16rpx;
  padding: 0 32rpx 24rpx;
}
.filter-tab {
  padding: 12rpx 28rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  background: rgba(255,255,255,0.06);
  color: #999;
  border: 1rpx solid rgba(255,255,255,0.1);
}
.filter-tab.active {
  background: rgba(91,127,255,0.15);
  color: #5b7fff;
  border-color: #5b7fff;
}

/* 预约卡片 */
.booking-list { padding: 0 32rpx; }
.booking-card {
  background: rgba(255,255,255,0.04);
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255,255,255,0.08);
}
.booking-header {
  padding: 24rpx 28rpx;
  background: rgba(91,127,255,0.06);
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
}
.booking-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}
.booking-service { font-size: 32rpx; font-weight: 600; color: #fff; }
.booking-time { font-size: 22rpx; color: #666; }

.status-badge {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}
.status-pending { background: rgba(255,180,0,0.15); color: #ffb400; }
.status-confirmed { background: rgba(82,196,26,0.15); color: #52c41a; }
.status-completed { background: rgba(91,127,255,0.15); color: #5b7fff; }

.booking-body { padding: 20rpx 28rpx; }
.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 0;
}
.info-label { font-size: 26rpx; color: #999; flex-shrink: 0; }
.info-value { font-size: 26rpx; color: #ddd; text-align: right; }
.info-value.price { color: #5b7fff; font-weight: 600; }
.info-value.desc { max-width: 400rpx; word-break: break-all; }
.info-value.quote-detail { color: #5b7fff; }

.phone-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.phone-link { color: #5b7fff; }
.call-icon { font-size: 28rpx; }

.booking-footer {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 28rpx;
  border-top: 1rpx solid rgba(255,255,255,0.06);
}
.btn-status {
  flex: 1;
  font-size: 24rpx;
  background: #5b7fff;
  color: #fff;
  border-radius: 20rpx;
  padding: 10rpx 0;
  line-height: 1.6;
  border: none;
}
.btn-status::after { border: none; }
.btn-contact {
  font-size: 24rpx;
  background: transparent;
  color: #999;
  border: 1rpx solid rgba(255,255,255,0.2);
  border-radius: 20rpx;
  padding: 10rpx 20rpx;
  line-height: 1.6;
}
.btn-contact::after { border: none; }

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 32rpx;
}
.empty-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 28rpx; color: #999; }
